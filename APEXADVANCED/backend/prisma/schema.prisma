generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id           String   @id
  name         String
  brand        String
  category     String
  price        Float
  description  String
  image        String
  stock        Int
  stockStatus  String
  specs        String   // Stored as JSON string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Shop {
  id        String   @id
  name      String
  city      String
  lat       Float
  lng       Float
  address   String
  phone     String?
  hours     String?
  services  String?  // Stored as JSON string
  rating    Float?   @default(4.5)
  image     String?
  isOpen    Boolean? @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bike {
  id                   String   @id
  name                 String
  brand                String
  model                String
  year                 String   // JSON has it as string "2024"
  basePrice            Float
  image                String
  stats                String?  // Stored as JSON string
  compatibleCategories String?  // Stored as JSON string
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Order {
  id             String   @id
  orderNumber    String   @unique
  customerName   String
  total          Float
  status         String
  items          String?  // Stored as JSON string
  timeline       String?  // Stored as JSON string
  trackingNumber String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
