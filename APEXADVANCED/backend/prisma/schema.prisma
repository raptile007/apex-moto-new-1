generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id
  name        String
  brand       String
  category    String
  price       Float
  description String
  image       String
  stock       Int
  stockStatus String
  specs       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stats       String?
}

model Shop {
  id        String   @id
  name      String
  city      String
  lat       Float
  lng       Float
  address   String
  phone     String?
  hours     String?
  services  String?
  rating    Float?   @default(4.5)
  image     String?
  isOpen    Boolean? @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bike {
  id                   String   @id
  name                 String
  brand                String
  model                String
  year                 String
  basePrice            Float
  image                String
  stats                String?
  compatibleCategories String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Order {
  id                String   @id
  orderNumber       String   @unique
  customerName      String
  total             Float
  status            String
  items             String?
  timeline          String?
  trackingNumber    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customerEmail     String?
  customerId        String?
  customerPhone     String?
  estimatedDelivery String?
  paymentMethod     String?
  paymentStatus     String?
  shipping          Float?
  shippingAddress   String?
  subtotal          Float?
  tax               Float?
}

model GarageBuild {
  id        String   @id
  name      String
  bike      String   // JSON string
  parts     String   // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Telemetry {
  id        String   @id
  label     String
  value     Float
  unit      String
  trend     String
  color     String
  updatedAt DateTime @updatedAt
}

model Achievement {
  id          String    @id
  title       String
  description String
  rarity      String
  unlockedAt  DateTime?
  progress    Int       @default(0)
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id        String   @id
  shopId    String
  shopName  String
  service   String
  date      String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // "order" or "booking"
  action    String
  details   String?  // JSON string
  createdAt DateTime @default(now())
}
